{
  "extends": "galileo/base",
  "meta": {
    "description": "Main CTS benchmark preset for paper-grade constrained RL comparison.",
    "benchmark": "cts_main",
    "recommended_seeds": [
      11,
      22,
      33,
      44,
      55
    ],
    "primary_metrics": [
      "reward",
      "constraint_violation",
      "sample_efficiency",
      "wall_clock_efficiency"
    ]
  },
  "agent": {
    "experiment_name": "galileo_benchmark_cts_main",
    "num_steps_per_env": 48,
    "save_interval": 100,
    "max_iterations": 20000
  },
  "env": {
    "scene": {
      "terrain": {
        "max_init_terrain_level": 1
      }
    }
  }
}
